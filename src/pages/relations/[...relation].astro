---
import Head from '@components/Head.astro';
import Header from '@components/Header.astro';
import { buildRelationsGraph } from '@/lib/relations-graph';
import { slugToHref } from '@/lib/slugs';
import type { PageRelations, RelationTarget } from '@/lib/relations';

const RELATION_LABELS: Record<keyof PageRelations, string> = {
  part_of: 'part of',
  has_part: 'has part',
  is: 'is',
  has: 'has',
  subclass_of: 'subclass of',
  superclass_of: 'superclass of',
  subject: 'subject',
  subject_of: 'subject of',
  creator: 'creator',
  creator_of: 'creator of',
  related: 'related',
  up: 'up',
  down: 'down',
  prev: 'prev',
  next: 'next',
  ref: 'ref',
  refi: 'refi',
};

const RELATION_KEYS = Object.keys(RELATION_LABELS) as (keyof PageRelations)[];

function relationTargets(relations: PageRelations, key: keyof PageRelations): RelationTarget[] {
  const value = relations[key];
  if (!value) return [];

  if (Array.isArray(value)) {
    return value.map((target) => typeof target === 'string'
      ? { slug: target }
      : target,
    );
  }

  return typeof value === 'string' ? [{ slug: value }] : [];
}

export async function getStaticPaths() {
  const { graph, pages } = await buildRelationsGraph();
  const keys = [
    'part_of', 'has_part', 'is', 'has', 'subclass_of', 'superclass_of',
    'subject', 'subject_of', 'creator', 'creator_of', 'related',
    'up', 'down', 'prev', 'next', 'ref', 'refi',
  ] as (keyof PageRelations)[];
  const paths = [];

  for (const [slug, relations] of graph) {
    const source = pages.get(slug);
    if (!source) continue;

    for (const key of keys) {
      const value = relations[key];
      if (!value) continue;

      const targets = Array.isArray(value)
        ? value.map((target) => typeof target === 'string' ? { slug: target } : target)
        : typeof value === 'string'
          ? [{ slug: value }]
          : [];
      if (targets.length === 0) continue;

      paths.push({
        params: { relation: `${slug}/${key}` },
        props: { slug, key, targets },
      });
    }
  }

  return paths;
}

const { slug, key, targets } = Astro.props as {
  slug: string;
  key: keyof PageRelations;
  targets: RelationTarget[];
};

const { pages } = await buildRelationsGraph();
const sourceTitle = pages.get(slug)?.title ?? slug;
const relationLabel = RELATION_LABELS[key];
const title = `${sourceTitle}: ${relationLabel}`;

function getTitle(targetSlug: string): string {
  return pages.get(targetSlug)?.title ?? targetSlug;
}
---

<!DOCTYPE html>
<html lang="en">
  <Head title={title} description={`Pages connected to ${sourceTitle} by ${relationLabel}.`} />
  <body class="has-site-header">
    <Header />
    <main class="min-w-0 py-4">
      <article class="service-page">
        <header class="mb-4">
          <p class="service-kicker">relation</p>
          <h1>{title}</h1>
          <p class="text-text-muted italic mb-2">
            <a href={slugToHref(slug)}>{sourceTitle}</a> / {relationLabel}
          </p>
        </header>

        <div class="prose">
          <ul>
            {targets.map((target) => (
              <li>
                <a href={slugToHref(target.slug)}>
                  {target.label ? `${target.label}: ` : ''}{getTitle(target.slug)}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </article>
    </main>
    <script>
      import '@/scripts/popups/index';
    </script>
  </body>
</html>

<style>
  .service-page {
    max-width: 70ch;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .service-kicker {
    margin: 0 0 0.35rem;
    font-family: var(--font-mono);
    font-size: var(--text-3xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }
</style>
