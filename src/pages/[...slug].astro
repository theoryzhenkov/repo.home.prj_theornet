---
import { getCollection, getEntry, render } from 'astro:content';
import Page from '@layouts/page/Page.astro';
import { getBreadcrumbs, getPageRelations } from '@/lib/relations';
import { buildRelationsGraph } from '@/lib/relations-graph';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages
    .filter((page) => page.id !== 'index')
    .map((page) => ({
      params: { slug: page.id },
    }));
}

const { slug } = Astro.params;
const entry = await getEntry('pages', slug!);

if (!entry) {
  return Astro.redirect('/404');
}

const { Content, headings } = await render(entry);
const { data } = entry;

// Build relations graph
const { graph, pages } = await buildRelationsGraph();
const breadcrumbs = getBreadcrumbs(slug!, graph, pages);
const relations = getPageRelations(slug!, graph);

// Compute read time from body word count
const wordCount = entry.body ? entry.body.split(/\s+/).filter(Boolean).length : 0;
const readTimeMinutes = Math.max(1, Math.round(wordCount / 238));

// Compute per-heading word counts for TOC
const body = entry.body || '';
const headingPositions: { depth: number; slug: string; text: string; position: number }[] = [];
const headingRegex = /^(#{2,3})\s+(.+)$/gm;
let match;
while ((match = headingRegex.exec(body)) !== null) {
  const depth = match[1].length;
  const text = match[2].trim();
  const headingSlug = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  headingPositions.push({ depth, slug: headingSlug, text, position: match.index });
}

const enrichedHeadings = headings.map((h) => {
  if (h.depth < 2 || h.depth > 3) return h;

  // Find this heading in the source positions
  const idx = headingPositions.findIndex((hp) => hp.slug === h.slug);
  if (idx === -1) return h;

  // Find next heading of same or higher level
  const start = headingPositions[idx].position;
  let end = body.length;
  for (let i = idx + 1; i < headingPositions.length; i++) {
    if (headingPositions[i].depth <= headingPositions[idx].depth) {
      end = headingPositions[i].position;
      break;
    }
  }

  const sectionText = body.slice(start, end);
  const sectionWordCount = sectionText.split(/\s+/).filter(Boolean).length;
  return { ...h, wordCount: sectionWordCount };
});

// Build backlinks from refi
const backlinks = (relations?.refi ?? []).map((refSlug) => {
  const pageInfo = pages.get(refSlug);
  return {
    title: pageInfo?.title ?? refSlug,
    slug: refSlug,
  };
});
---

<Page
  title={data.title}
  description={data.description}
  created={data.created}
  modified={data.modified}
  maturity={data.maturity}
  headings={enrichedHeadings}
  breadcrumbs={breadcrumbs}
  currentSlug={slug!}
  relations={relations}
  pageInfoMap={pages}
  links={data.links}
  readTimeMinutes={readTimeMinutes}
  backlinks={backlinks}
>
  <Content />
</Page>
