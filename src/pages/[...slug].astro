---
import Page from '@layouts/page/Page.astro';
import MetadataPage from '@layouts/metadata/MetadataPage.astro';
import ContentTable from '@components/content/ContentTable.astro';
import LinkCards from '@components/content/LinkCards.astro';
import NotesFeed from '@components/notes/NotesFeed.astro';
import { getBreadcrumbs, getPageRelations } from '@/lib/relations';
import { buildRelationsGraph } from '@/lib/relations-graph';
import { getSiteRouteEntries, getSiteRouteEntry } from '@/lib/site-pages';
import { estimateHtmlReadTimeMinutes } from '@/lib/html-content';

export async function getStaticPaths() {
  const entries = await getSiteRouteEntries();
  const paths = [];
  for (const entry of entries) {
    // Index has its own route (src/pages/index.astro); everything else is here.
    if (entry.id !== 'index') {
      paths.push({ params: { slug: entry.id }, props: { metadataFor: null } });
    }
    // Every page has a dedicated metadata page at <slug>/metadata (/metadata
    // for the index).
    const metaSlug = entry.id === 'index' ? 'metadata' : `${entry.id}/metadata`;
    paths.push({ params: { slug: metaSlug }, props: { metadataFor: entry.id } });
  }
  return paths;
}

const { slug } = Astro.params;
const { metadataFor } = Astro.props as { metadataFor: string | null };
const targetSlug = metadataFor ?? slug!;
const entry = await getSiteRouteEntry(targetSlug);

if (!entry) {
  return Astro.redirect('/404');
}

const data = entry.data;
const body = entry.body ?? '';
const Content = entry.mdx.Content;
const mdxComponents = { ContentTable, LinkCards, NotesFeed };
const baseHeadings = entry.mdx.headings
  .filter((heading) => heading.depth >= 2 && heading.depth <= 5)
  .map((heading) => ({
    depth: heading.depth,
    slug: heading.slug,
    text: heading.text,
  }));

// Build relations graph
const { graph, pages } = await buildRelationsGraph();
const breadcrumbs = getBreadcrumbs(targetSlug, graph, pages);
const relations = getPageRelations(targetSlug, graph);
const readTimeMinutes = estimateHtmlReadTimeMinutes(body);

const enrichedHeadings = baseHeadings;

// Build backlinks from refi
const backlinks = (relations?.refi ?? []).map((refSlug) => {
  const pageInfo = pages.get(refSlug);
  return {
    title: pageInfo?.title ?? refSlug,
    slug: refSlug,
  };
});

---

{metadataFor ? (
  <MetadataPage
    title={data.title}
    currentSlug={targetSlug}
    created={data.created}
    modified={data.modified}
    maturity={data.maturity}
    breadcrumbs={breadcrumbs}
    relations={relations}
    pageInfoMap={pages}
    readTimeMinutes={readTimeMinutes}
    backlinks={backlinks}
  />
) : (
  <Page
    title={data.title}
    description={data.description}
    created={data.created}
    modified={data.modified}
    maturity={data.maturity}
    banner={data.banner}
    bannerAlt={data.bannerAlt}
    bannerCaption={data.bannerCaption}
    headings={enrichedHeadings}
    breadcrumbs={breadcrumbs}
    currentSlug={slug!}
    relations={relations}
    pageInfoMap={pages}
    readTimeMinutes={readTimeMinutes}
    backlinks={backlinks}
  >
    <Content components={mdxComponents} />
  </Page>
)}
