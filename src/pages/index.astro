---
import Page from '@layouts/page/Page.astro';
import ContentTable from '@components/content/ContentTable.astro';
import LinkCards from '@components/content/LinkCards.astro';
import GhostNotesFeed from '@components/ghost/GhostNotesFeed.astro';
import { getBreadcrumbs, getPageRelations } from '@/lib/relations';
import { buildRelationsGraph } from '@/lib/relations-graph';
import { getGhostRouteEntry } from '@/lib/site-pages';
import { addHeadingIds, estimateHtmlReadTimeMinutes, extractHtmlHeadings } from '@/lib/ghost';
import { parseHomeShortcodes } from '@/lib/home-shortcodes';

const entry = await getGhostRouteEntry('index');
if (!entry) {
  return Astro.redirect('/404');
}

const data = entry.data;
const ghostHtml = addHeadingIds(entry.html);
const ghostBlocks = parseHomeShortcodes(ghostHtml);
const headings = extractHtmlHeadings(ghostHtml);

// Build relations graph
const { graph, pages } = await buildRelationsGraph();
const breadcrumbs = getBreadcrumbs('index', graph, pages);
const relations = getPageRelations('index', graph);
const readTimeMinutes = estimateHtmlReadTimeMinutes(ghostHtml);

// Build backlinks from refi
const backlinks = (relations?.refi ?? []).map((refSlug) => {
  const pageInfo = pages.get(refSlug);
  return {
    title: pageInfo?.title ?? refSlug,
    slug: refSlug,
  };
});

const defaultContentTableColumns = [
  { field: 'title', label: 'Title', sortable: true, type: 'link' as const },
  { field: 'description', label: 'Description' },
  { field: 'created', label: 'Created', sortable: true, type: 'date' as const },
];
---

<Page
  title={data.title}
  description={data.description}
  created={data.created}
  modified={data.modified}
  maturity={data.maturity}
  headings={headings}
  breadcrumbs={breadcrumbs}
  currentSlug="index"
  relations={relations}
  pageInfoMap={pages}
  readTimeMinutes={readTimeMinutes}
  backlinks={backlinks}
>
  {ghostBlocks.map((block) => {
    if (block.type === 'html') return <Fragment set:html={block.html} />;
    if (block.type === 'notes-feed') return <GhostNotesFeed />;
    if (block.type === 'link-cards') return <LinkCards links={block.links as any} />;
    return <ContentTable
      path={block.path}
      classSlug={block.classSlug}
      columns={defaultContentTableColumns}
      defaultSort={{ field: block.classSlug ? 'created' : 'title', direction: block.classSlug ? 'desc' : 'asc' }}
    />;
  })}
</Page>
