---
import { getTangentNotes, type SiteNote } from '@/lib/tangent-notes';

interface NoteThread {
  root: SiteNote;
  replies: SiteNote[];
  lastActivity: Date;
  tags: string[];
  searchText: string;
}

const notes = await getTangentNotes();

const fediverseHandle = import.meta.env.PUBLIC_FEDIVERSE_HANDLE || '@theor@theor.net';
const mastodonInstance = (import.meta.env.PUBLIC_MASTODON_INSTANCE_URL || 'https://mastodon.social').replace(/\/$/, '');
const mastodonHandlePath = fediverseHandle.replace(/^@/, '');
const mastodonProfileUrl = `${mastodonInstance}/@${mastodonHandlePath}`;

function formatDateTime(date: Date): string {
  return new Intl.DateTimeFormat('en', {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    timeZoneName: 'short',
  }).format(date);
}

function noteTimestamp(note: SiteNote): Date {
  return note.updated ?? note.published;
}

function noteKeys(note: SiteNote): string[] {
  return [note.id, note.sourceUrl].filter(Boolean);
}

function replyIntentUrl(note: SiteNote): string {
  const url = new URL('/share', mastodonInstance);
  url.searchParams.set('text', `${fediverseHandle} ${note.sourceUrl}`);
  return url.toString();
}

function uniqueSorted(values: string[]): string[] {
  return [...new Set(values)].sort((a, b) => a.localeCompare(b));
}

function groupThreads(items: SiteNote[]): NoteThread[] {
  const noteByKey = new Map<string, SiteNote>();
  for (const note of items) {
    for (const key of noteKeys(note)) noteByKey.set(key, note);
  }

  const rootById = new Map<string, SiteNote>();
  function rootFor(note: SiteNote): SiteNote {
    const cached = rootById.get(note.id);
    if (cached) return cached;

    const parent = note.inReplyTo ? noteByKey.get(note.inReplyTo) : undefined;
    const root = parent ? rootFor(parent) : note;
    rootById.set(note.id, root);
    return root;
  }

  const repliesByRoot = new Map<string, SiteNote[]>();
  const childIds = new Set<string>();

  for (const note of items) {
    const root = rootFor(note);
    if (root.id === note.id) continue;

    childIds.add(note.id);
    repliesByRoot.set(root.id, [...(repliesByRoot.get(root.id) ?? []), note]);
  }

  return items
    .filter((note) => !childIds.has(note.id))
    .map((root) => {
      const replies = (repliesByRoot.get(root.id) ?? [])
        .filter((reply) => reply.id !== root.id)
        .sort((a, b) => a.published.getTime() - b.published.getTime());
      const threadNotes = [root, ...replies];
      const lastActivity = replies.reduce(
        (latest, reply) => noteTimestamp(reply).getTime() > latest.getTime() ? noteTimestamp(reply) : latest,
        noteTimestamp(root),
      );
      return {
        root,
        replies,
        lastActivity,
        tags: uniqueSorted(threadNotes.flatMap((note) => note.tags)),
        searchText: threadNotes.map((note) => note.searchText).join(' '),
      };
    })
    .sort((a, b) => b.lastActivity.getTime() - a.lastActivity.getTime());
}

const threads = groupThreads(notes);
const allTags = uniqueSorted(threads.flatMap((thread) => thread.tags));
---

<section class="notes-feed" aria-label="Public notes from the Theor Fediverse account" data-notes-feed>
  <div class="notes-feed-toolbar">
    <a class="notes-feed-profile no-icon" href={mastodonProfileUrl} rel="me">Follow / reply</a>
    <label class="notes-feed-search-label">
      <span>Search notes</span>
      <input class="notes-feed-search" type="search" placeholder="Search note text…" data-notes-search />
    </label>
  </div>

  {allTags.length > 0 && (
    <nav class="notes-feed-tags" aria-label="Filter notes by tag">
      <a class="notes-feed-tag no-icon" href="/notes/" data-notes-tag="">all</a>
      {allTags.map((tag) => (
        <a class="notes-feed-tag no-icon" href={`/notes/?tag=${encodeURIComponent(tag)}`} data-notes-tag={tag}>#{tag}</a>
      ))}
    </nav>
  )}

  <p class="notes-feed-filter-state" data-notes-filter-state hidden></p>

  {threads.length > 0 ? (
    <ol class="note-thread-list">
      {threads.map((thread) => {
        const noteCount = thread.replies.length + 1;
        return (
          <li
            class="note-thread"
            data-has-replies={thread.replies.length > 0 ? 'true' : 'false'}
            data-note-tags={thread.tags.join(' ')}
            data-note-search={thread.searchText}
          >
            <article class="note-card" data-depth="root">
              <header class="note-meta">
                <a class="note-date no-icon" href={thread.root.sourceUrl} target="_blank" rel="noopener noreferrer">
                  <time datetime={thread.root.published.toISOString()}>{formatDateTime(thread.root.published)}</time>
                </a>
                {thread.replies.length > 0 && (
                  <a class="note-thread-label no-icon" href={thread.root.sourceUrl} target="_blank" rel="noopener noreferrer">
                    thread · {noteCount} notes
                  </a>
                )}
              </header>

              {thread.root.inReplyTo && <a class="note-reply-context no-icon" href={thread.root.inReplyTo}>replying to another note</a>}
              <div class="note-content" set:html={thread.root.contentHtml} />

              <footer class="note-actions">
                <a class="note-action no-icon" href={thread.root.sourceUrl} target="_blank" rel="noopener noreferrer">permalink</a>
                <span aria-hidden="true">·</span>
                <a class="note-action no-icon" href={replyIntentUrl(thread.root)} target="_blank" rel="noopener noreferrer">reply</a>
              </footer>
            </article>

            {thread.replies.length > 0 && (
              <ol class="note-replies" aria-label="Thread replies">
                {thread.replies.map((reply) => (
                  <li>
                    <article class="note-card" data-depth="reply">
                      <header class="note-meta">
                        <a class="note-date no-icon" href={reply.sourceUrl} target="_blank" rel="noopener noreferrer">
                          <time datetime={reply.published.toISOString()}>{formatDateTime(reply.published)}</time>
                        </a>
                      </header>

                      <div class="note-content" set:html={reply.contentHtml} />

                      <footer class="note-actions">
                        <a class="note-action no-icon" href={reply.sourceUrl} target="_blank" rel="noopener noreferrer">permalink</a>
                        <span aria-hidden="true">·</span>
                        <a class="note-action no-icon" href={replyIntentUrl(reply)} target="_blank" rel="noopener noreferrer">reply</a>
                      </footer>
                    </article>
                  </li>
                ))}
              </ol>
            )}
          </li>
        );
      })}
    </ol>
  ) : (
    <p class="notes-feed-empty">No public notes are available yet.</p>
  )}

  <p class="notes-feed-empty" data-notes-empty-filter hidden>No notes match this filter.</p>
</section>

<script>
  function initNotesFeedFilters() {
    const feed = document.querySelector('[data-notes-feed]');
    if (!(feed instanceof HTMLElement)) return;

    const search = feed.querySelector('[data-notes-search]');
    const state = feed.querySelector('[data-notes-filter-state]');
    const empty = feed.querySelector('[data-notes-empty-filter]');
    const threads = [...feed.querySelectorAll('.note-thread')].filter((item): item is HTMLElement => item instanceof HTMLElement);
    const tagLinks = [...feed.querySelectorAll('[data-notes-tag]')].filter((item): item is HTMLAnchorElement => item instanceof HTMLAnchorElement);

    const params = new URLSearchParams(window.location.search);
    let activeTag = (params.get('tag') || '').toLowerCase();

    function applyFilters() {
      const query = search instanceof HTMLInputElement ? search.value.trim().toLowerCase() : '';
      let visible = 0;

      for (const thread of threads) {
        const tags = (thread.dataset.noteTags || '').split(/\s+/).filter(Boolean);
        const text = thread.dataset.noteSearch || '';
        const matchesTag = !activeTag || tags.includes(activeTag);
        const matchesSearch = !query || text.includes(query);
        const show = matchesTag && matchesSearch;
        thread.hidden = !show;
        if (show) visible += 1;
      }

      for (const link of tagLinks) {
        link.dataset.active = (link.dataset.notesTag || '') === activeTag ? 'true' : 'false';
      }

      if (state instanceof HTMLElement) {
        const parts = [activeTag ? `tag #${activeTag}` : '', query ? `search “${query}”` : ''].filter(Boolean);
        state.textContent = parts.length > 0 ? `Showing ${visible} thread${visible === 1 ? '' : 's'} for ${parts.join(' + ')}.` : '';
        state.hidden = parts.length === 0;
      }
      if (empty instanceof HTMLElement) empty.hidden = visible !== 0;
    }

    for (const link of tagLinks) {
      link.addEventListener('click', (event) => {
        event.preventDefault();
        activeTag = (link.dataset.notesTag || '').toLowerCase();
        const next = new URL(window.location.href);
        if (activeTag) next.searchParams.set('tag', activeTag);
        else next.searchParams.delete('tag');
        window.history.replaceState({}, '', next);
        applyFilters();
      });
    }

    if (search instanceof HTMLInputElement) {
      search.addEventListener('input', applyFilters);
    }

    applyFilters();
  }

  document.addEventListener('astro:page-load', initNotesFeedFilters);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNotesFeedFilters);
  } else {
    initNotesFeedFilters();
  }
</script>
