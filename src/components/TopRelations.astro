---
import type { PageRelations, PageInfoMap, RelationTarget } from '@/lib/relations';

interface Props {
  relations: PageRelations;
  pages: PageInfoMap;
  links?: Record<string, string>;
}

const { relations, pages, links } = Astro.props;

function getHref(slug: string): string {
  return slug === 'index' ? '/' : `/${slug}/`;
}

function getTitle(slug: string): string {
  return pages.get(slug)?.title ?? slug;
}

interface RelationRow {
  label: string;
  targets: RelationTarget[];
}

const rows: RelationRow[] = [];

if (relations.up.length > 0) {
  rows.push({ label: 'Up', targets: relations.up });
}
if (relations.down.length > 0) {
  rows.push({ label: 'Down', targets: relations.down });
}
if (relations.is.length > 0) {
  rows.push({ label: 'Is', targets: relations.is });
}
if (relations.has.length > 0) {
  rows.push({ label: 'Has', targets: relations.has });
}
if (relations.prev) {
  rows.push({ label: 'Prev', targets: [{ slug: relations.prev }] });
}
if (relations.next) {
  rows.push({ label: 'Next', targets: [{ slug: relations.next }] });
}
if (relations.ref.length > 0) {
  rows.push({ label: 'Ref', targets: relations.ref.map(s => ({ slug: s })) });
}
if (relations.refi.length > 0) {
  rows.push({ label: 'Refi', targets: relations.refi.map(s => ({ slug: s })) });
}

const hasRelations = rows.length > 0;
const hasLinks = links && Object.keys(links).length > 0;
const hasAny = hasRelations || hasLinks;
---

{hasAny && (
  <aside class="top-relations">
    {rows.map((row) => (
      <div class="top-relations-row">
        <span class="top-relations-label">{row.label}:</span>
        {row.targets.map((target, i) => (
          <>
            {i > 0 && <span class="top-relations-sep">,</span>}
            <a href={getHref(target.slug)}>
              {target.label ? `${target.label}: ` : ''}{getTitle(target.slug)}
            </a>
          </>
        ))}
      </div>
    ))}
    {hasLinks && (
      <div class="top-relations-row">
        <span class="top-relations-label">Links:</span>
        {Object.entries(links!).map(([type, url], i) => (
          <>
            {i > 0 && <span class="top-relations-sep">,</span>}
            <a href={url} target="_blank" rel="noopener noreferrer">{type}</a>
          </>
        ))}
      </div>
    )}
  </aside>
)}

<style>
  .top-relations {
    margin-bottom: theme(spacing.2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .top-relations-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: theme(spacing.1);
  }

  .top-relations-label {
    color: var(--color-text-subtle);
  }

  .top-relations-sep {
    color: var(--color-text-subtle);
  }

  .top-relations a {
    color: var(--color-link);
    text-decoration: underline;
  }

  .top-relations a:hover {
    color: var(--color-link-hover);
  }
</style>
