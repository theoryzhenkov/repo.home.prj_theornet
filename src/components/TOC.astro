---
interface Heading {
  depth: number;
  slug: string;
  text: string;
  wordCount?: number;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

const WPM = 238;

// Filter to h2 and h3
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

// Compute read time per heading: words from this heading to next heading of same/higher level
function computeReadTime(wordCount: number | undefined): string {
  if (wordCount === undefined || wordCount === 0) return '';
  const minutes = wordCount / WPM;
  if (minutes < 1) return '< 1m';
  return `${Math.round(minutes)}m`;
}

// Group headings: each h2 starts a group, h3s belong to the preceding h2's group
interface TocGroup {
  entries: { heading: Heading; time: string }[];
}

const groups: TocGroup[] = [];
let currentGroup: TocGroup | null = null;

for (const heading of tocHeadings) {
  const time = computeReadTime(heading.wordCount);
  if (heading.depth === 2) {
    currentGroup = { entries: [{ heading, time }] };
    groups.push(currentGroup);
  } else if (currentGroup) {
    currentGroup.entries.push({ heading, time });
  } else {
    // h3 without a preceding h2 — create its own group
    currentGroup = { entries: [{ heading, time }] };
    groups.push(currentGroup);
  }
}
---

{tocHeadings.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <span class="toc-label">CONTENTS</span>
    <div class="toc-separator"></div>
    <div class="toc-items">
      {groups.map((group) => (
        <div class="toc-group">
          {group.entries.map((entry) => (
            <a
              class="toc-entry"
              data-state="unread"
              data-depth={entry.heading.depth}
              href={`#${entry.heading.slug}`}
            >
              <span class="toc-text">{entry.heading.text}</span>
              {entry.time && <span class="toc-time">{entry.time}</span>}
            </a>
          ))}
        </div>
      ))}
    </div>
  </nav>
)}

<script>
  import '@/scripts/toc-scrollspy';
</script>
