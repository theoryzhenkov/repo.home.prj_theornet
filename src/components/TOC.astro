---
import { buildTocTree, type Heading } from './toc-tree';
import TocList from './TocList.astro';

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Show h2 through h5, nested as a tree.
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 5);
const tree = buildTocTree(tocHeadings);
---

{tocHeadings.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <span class="toc-label">CONTENTS</span>
    <div class="toc-separator"></div>
    <div class="toc-items">
      <TocList nodes={tree} />
    </div>
  </nav>
)}

<script>
  import '@/scripts/toc-scrollspy';
</script>
