---
import type { PageInfo } from '@/lib/relations';
import { slugToHref } from '@/lib/slugs';

interface Props {
  breadcrumbs: PageInfo[];
  currentSlug: string;
}

const { breadcrumbs, currentSlug } = Astro.props;

// Don't render if no breadcrumbs or only current page
if (breadcrumbs.length <= 1) {
  return null;
}
---

<nav class="breadcrumb metadata-relations" aria-label="Breadcrumb">
  <span class="metadata-relation-row">
    <span class="metadata-relation-label">breadcrumbs:</span>
    <span class="metadata-relation-values breadcrumb-list">
    {breadcrumbs.map((page, index) => {
      const isLast = index === breadcrumbs.length - 1;
      const isHome = page.slug === 'index';
      const label = isHome ? 'Home' : page.title;
      
      return (
        <span class="breadcrumb-item metadata-relation-item">
          {index > 0 && <span class="breadcrumb-separator" aria-hidden="true">/</span>}
          {!isLast ? (
            <a href={slugToHref(page.slug)} class="metadata-link breadcrumb-link">
              {label}
            </a>
          ) : (
            <span class="breadcrumb-current" aria-current="page">
              {label}
            </span>
          )}
        </span>
      );
    })}
    </span>
  </span>
</nav>

