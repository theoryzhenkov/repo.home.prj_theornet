---
import type { PageRelations, PageInfoMap, RelationTarget, PageInfo } from '@/lib/relations';
import { slugToHref } from '@/lib/slugs';
import Breadcrumb from '@components/Breadcrumb.astro';

interface Props {
  created: Date;
  modified?: Date;
  maturity?: 'stub' | 'rough' | 'developed';
  readTimeMinutes?: number;
  backlinksCount?: number;
  currentSlug: string;
  breadcrumbs?: PageInfo[];
  relations?: PageRelations;
  pageInfoMap?: PageInfoMap;
  // `inline` shows only the most important fields plus a link to the full
  // metadata page; `full` shows everything (used on /<slug>/metadata).
  variant?: 'inline' | 'full';
  metadataHref?: string;
}

const {
  created,
  modified,
  maturity,
  readTimeMinutes,
  backlinksCount = 0,
  currentSlug,
  breadcrumbs = [],
  relations,
  pageInfoMap,
  variant = 'inline',
  metadataHref,
} = Astro.props;

const isInline = variant !== 'full';

// Inline keeps only the highest-value relations; the rest live on the
// dedicated metadata page.
const IMPORTANT_RELATIONS = new Set<keyof PageRelations>(['part_of', 'has_part', 'is']);

function formatDate(date: Date): string {
  return date.toISOString().slice(0, 10);
}

// Show updated date only if it differs from created by > 24h
const showUpdated = modified && Math.abs(modified.getTime() - created.getTime()) > 86_400_000;

// Freshness: months since last update
function getFreshness(date: Date): { text: string; stale: boolean } | null {
  const now = new Date();
  const months = (now.getFullYear() - date.getFullYear()) * 12 + (now.getMonth() - date.getMonth());
  if (months <= 6) return null;
  const years = Math.floor(months / 12);
  const remainingMonths = months % 12;
  const text = years > 0 ? `${years}y${remainingMonths > 0 ? ` ${remainingMonths}mo` : ''} ago` : `${months}mo ago`;
  return { text, stale: months > 24 };
}

const freshness = showUpdated && modified ? getFreshness(modified) : null;

// Relations rendering
interface RelationRow {
  key: keyof PageRelations;
  label: string;
  targets: { slug: string; label?: string }[];
  extraCount?: number;
}

function getTitle(slug: string): string {
  return pageInfoMap?.get(slug)?.title ?? slug;
}

const relationOrder: { key: keyof PageRelations; label: string }[] = [
  { key: 'part_of', label: 'part of' },
  { key: 'has_part', label: 'has part' },
  { key: 'is', label: 'is' },
  { key: 'has', label: 'has' },
  { key: 'subclass_of', label: 'subclass of' },
  { key: 'superclass_of', label: 'superclass of' },
  { key: 'subject', label: 'subject' },
  { key: 'subject_of', label: 'subject of' },
  { key: 'creator', label: 'creator' },
  { key: 'creator_of', label: 'creator of' },
  { key: 'related', label: 'related' },
  { key: 'up', label: 'up' },
  { key: 'down', label: 'down' },
  { key: 'prev', label: 'prev' },
  { key: 'next', label: 'next' },
  { key: 'ref', label: 'ref' },
  { key: 'refi', label: 'refi' },
];

const relationRows: RelationRow[] = [];
if (relations) {
  for (const { key, label } of relationOrder) {
    if (isInline && !IMPORTANT_RELATIONS.has(key)) continue;
    const val = relations[key];
    if (!val) continue;
    if (Array.isArray(val)) {
      if (val.length === 0) continue;
      const targets = val.map((v: RelationTarget | string) =>
        typeof v === 'string' ? { slug: v } : v,
      );
      const visibleTargets = isInline ? targets.slice(0, 6) : targets;
      const extraCount = targets.length > visibleTargets.length
        ? targets.length - visibleTargets.length
        : undefined;
      relationRows.push({ key, label, targets: visibleTargets, extraCount });
    } else if (typeof val === 'string') {
      relationRows.push({ key, label, targets: [{ slug: val }] });
    }
  }
}
---

<aside class:list={['metadata-strip', { 'metadata-full': !isInline }]}>
  {isInline ? (
    <div class="metadata-inline">
      {/* Items end adjacent to </span> on purpose: trailing whitespace inside an
         item would render a space before the ::after semicolon. */}
      {maturity && (
        <span class="metadata-inline-item metadata-maturity-label" data-maturity={maturity}><span class="metadata-maturity-dot" data-maturity={maturity}></span>{maturity}</span>
      )}
      {showUpdated && modified && (
        <span class="metadata-inline-item"><span class="metadata-inline-label">updated</span> <time datetime={modified.toISOString()}>{formatDate(modified)}</time>{freshness && (<span class:list={['metadata-freshness', { stale: freshness.stale }]}> ({freshness.text})</span>)}</span>
      )}
      {relationRows.map((row) => (
        <span class="metadata-inline-item"><span class="metadata-rel-label">{row.label}</span> {row.targets.map((target, index) => (<span class="metadata-relation-item"><a href={slugToHref(target.slug)} class="metadata-link metadata-value-link">{target.label ? `${target.label}: ` : ''}{getTitle(target.slug)}</a>{(index < row.targets.length - 1) ? <span class="metadata-sep" aria-hidden="true">, </span> : ''}</span>))}{row.extraCount ? <span class="metadata-relation-more">+{row.extraCount} more</span> : null}</span>
      ))}
      <span class="metadata-inline-item"><a href={`/graph/?focus=${currentSlug}`} class="metadata-link">graph</a></span>
      {metadataHref && (
        <span class="metadata-inline-item"><a href={metadataHref} class="metadata-link metadata-more-link">all metadata →</a></span>
      )}
    </div>
  ) : (
  <dl class="metadata-grid">
    {maturity && (
      <>
        <dt class="metadata-grid-label">status</dt>
        <dd class="metadata-grid-value">
          <span class="metadata-maturity-dot" data-maturity={maturity}></span>
          <span class="metadata-maturity-label" data-maturity={maturity}>{maturity}</span>
        </dd>
      </>
    )}

    {!isInline && breadcrumbs.length > 1 && (
      <>
        <dt class="metadata-grid-label">path</dt>
        <dd class="metadata-grid-value">
          <Breadcrumb breadcrumbs={breadcrumbs} currentSlug={currentSlug} />
        </dd>
      </>
    )}

    {!isInline && (
      <>
        <dt class="metadata-grid-label">created</dt>
        <dd class="metadata-grid-value">
          <time datetime={created.toISOString()}>{formatDate(created)}</time>
        </dd>
      </>
    )}

    {showUpdated && modified && (
      <>
        <dt class="metadata-grid-label">updated</dt>
        <dd class="metadata-grid-value">
          <time datetime={modified.toISOString()}>{formatDate(modified)}</time>
          {freshness && (
            <span class:list={['metadata-freshness', { stale: freshness.stale }]}> ({freshness.text})</span>
          )}
        </dd>
      </>
    )}

    {!isInline && readTimeMinutes !== undefined && readTimeMinutes >= 2 && (
      <>
        <dt class="metadata-grid-label">read</dt>
        <dd class="metadata-grid-value"><span class="metadata-num">{readTimeMinutes} min</span></dd>
      </>
    )}

    {relationRows.map((row) => (
      <>
        <dt class="metadata-grid-label">{row.label}</dt>
        <dd class="metadata-grid-value">
          {row.targets.map((target, index) => (
            <span class="metadata-relation-item">
              <a href={slugToHref(target.slug)} class="metadata-link">{target.label ? `${target.label}: ` : ''}{getTitle(target.slug)}</a>{(index < row.targets.length - 1) ? <span class="metadata-sep" aria-hidden="true">, </span> : ''}
            </span>
          ))}
          {row.extraCount ? <span class="metadata-relation-more">+{row.extraCount} more</span> : null}
        </dd>
      </>
    ))}
  </dl>
  )}

  {!isInline && (
    <div class="metadata-actions">
      <a href={`/graph/?focus=${currentSlug}`} class="metadata-link">graph</a>
      {backlinksCount > 0 && (
        <a href="#backlinks" class="metadata-link">{backlinksCount} backlinks</a>
      )}
    </div>
  )}
</aside>
