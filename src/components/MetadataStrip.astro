---
import type { PageRelations, PageInfoMap, RelationTarget } from '@/lib/relations';
import { slugToHref } from '@/lib/slugs';

interface Props {
  created: Date;
  modified?: Date;
  maturity?: 'stub' | 'rough' | 'developed';
  readTimeMinutes?: number;
  backlinksCount?: number;
  currentSlug: string;
  relations?: PageRelations;
  pageInfoMap?: PageInfoMap;
}

const {
  created,
  modified,
  maturity,
  readTimeMinutes,
  backlinksCount = 0,
  currentSlug,
  relations,
  pageInfoMap,
} = Astro.props;

function formatDate(date: Date): string {
  return date.toISOString().slice(0, 10);
}

// Show updated date only if it differs from created by > 24h
const showUpdated = modified && Math.abs(modified.getTime() - created.getTime()) > 86_400_000;

// Freshness: months since last update
function getFreshness(date: Date): { text: string; stale: boolean } | null {
  const now = new Date();
  const months = (now.getFullYear() - date.getFullYear()) * 12 + (now.getMonth() - date.getMonth());
  if (months <= 6) return null;
  const years = Math.floor(months / 12);
  const remainingMonths = months % 12;
  const text = years > 0 ? `${years}y${remainingMonths > 0 ? ` ${remainingMonths}mo` : ''} ago` : `${months}mo ago`;
  return { text, stale: months > 24 };
}

const freshness = showUpdated && modified ? getFreshness(modified) : null;

// Relations rendering
interface RelationRow {
  key: keyof PageRelations;
  label: string;
  targets: { slug: string; label?: string }[];
  extraCount?: number;
}

function getTitle(slug: string): string {
  return pageInfoMap?.get(slug)?.title ?? slug;
}

function relationHref(key: keyof PageRelations): string {
  return `/relations/${currentSlug}/${key}/`;
}

const relationOrder: { key: keyof PageRelations; label: string }[] = [
  { key: 'part_of', label: 'part of' },
  { key: 'has_part', label: 'has part' },
  { key: 'is', label: 'is' },
  { key: 'has', label: 'has' },
  { key: 'subclass_of', label: 'subclass of' },
  { key: 'superclass_of', label: 'superclass of' },
  { key: 'subject', label: 'subject' },
  { key: 'subject_of', label: 'subject of' },
  { key: 'creator', label: 'creator' },
  { key: 'creator_of', label: 'creator of' },
  { key: 'related', label: 'related' },
  { key: 'up', label: 'up' },
  { key: 'down', label: 'down' },
  { key: 'prev', label: 'prev' },
  { key: 'next', label: 'next' },
  { key: 'ref', label: 'ref' },
  { key: 'refi', label: 'refi' },
];

const relationRows: RelationRow[] = [];
if (relations) {
  for (const { key, label } of relationOrder) {
    const val = relations[key];
    if (!val) continue;
    if (Array.isArray(val)) {
      if (val.length === 0) continue;
      // val is RelationTarget[] or string[]
      const targets = val.map((v: RelationTarget | string) =>
        typeof v === 'string' ? { slug: v } : v,
      );
      const visibleTargets = targets.slice(0, 6);
      const extraCount = targets.length > visibleTargets.length
        ? targets.length - visibleTargets.length
        : undefined;
      relationRows.push({ key, label, targets: visibleTargets, extraCount });
    } else if (typeof val === 'string') {
      relationRows.push({ key, label, targets: [{ slug: val }] });
    }
  }
}

const hasRelationRows = relationRows.length > 0;
---

<aside class="metadata-strip">
  <div class="metadata-context">
    {maturity && (
        <span class="metadata-item metadata-maturity">
          <span class="metadata-maturity-dot" data-maturity={maturity}></span>
          <span class="metadata-maturity-label" data-maturity={maturity}>{maturity}</span>
        </span>
    )}
    {readTimeMinutes !== undefined && readTimeMinutes >= 2 && (
      <span class="metadata-item">
        <span class="metadata-item-value">{readTimeMinutes} min</span>
      </span>
    )}
    <span class="metadata-item">
      <span class="metadata-item-label">created</span>
      <time class="metadata-item-value" datetime={created.toISOString()}>{formatDate(created)}</time>
    </span>
    {showUpdated && modified && (
      <span class="metadata-item">
        <span class="metadata-item-label">updated</span>
        <time class="metadata-item-value" datetime={modified.toISOString()}>{formatDate(modified)}</time>
        {freshness && (
          <span class:list={['metadata-freshness', { stale: freshness.stale }]}>
            ({freshness.text})
          </span>
        )}
      </span>
    )}
    {backlinksCount > 0 && (
      <a href="#backlinks" class="metadata-item metadata-link">{backlinksCount} backlinks</a>
    )}
    <a href={`/graph/?focus=${currentSlug}`} class="metadata-item metadata-link">graph</a>
  </div>

  {hasRelationRows && (
    <div class="metadata-relations">
      {relationRows.map((row) => (
        <div class="metadata-relation-row">
          <a href={relationHref(row.key)} class="metadata-relation-label metadata-link">{row.label}:</a>
          <div class="metadata-relation-values">
            {row.targets.map((target, index) => (
              <span class="metadata-relation-item">
                <a href={slugToHref(target.slug)} class="metadata-link">{target.label ? `${target.label}: ` : ''}{getTitle(target.slug)}</a>{(index < row.targets.length - 1 || row.extraCount) ? ', ' : ''}
              </span>
            ))}
            {row.extraCount ? (
              <span class="metadata-relation-more">+{row.extraCount} more</span>
            ) : null}
          </div>
        </div>
      ))}
    </div>
  )}
</aside>
