---
// Eye / eye-off toggle for collapsible margin panels (TOC, metadata).
// The collapsible state lives on the parent ([data-collapsible]); this button
// only renders the control. Icons are Lucide (eye, eye-off).
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<button
  class="panel-toggle"
  type="button"
  data-panel-toggle
  aria-expanded="true"
  aria-label={`Hide ${label}`}
  title={`Hide ${label}`}
>
  <span class="icon icon-eye" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0" />
      <circle cx="12" cy="12" r="3" />
    </svg>
  </span>
  <span class="icon icon-eye-off" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49" />
      <path d="M14.084 14.158a3 3 0 0 1-4.242-4.242" />
      <path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143" />
      <path d="m2 2 20 20" />
    </svg>
  </span>
</button>
