---
const navItems = [
  { href: '/', label: 'index' },
  { href: '/projects/', label: 'projects' },
  { href: '/blog/', label: 'blog' },
  { href: '/contact', label: 'contact' }
];

const currentPath = Astro.url.pathname;
---

<div class="header-spacer"></div>
<header class="header" data-header>
  <div class="header-inner">
    <div class="header-left">
      <a href="/" class="header-mark">theor.net</a>
      <span class="header-sep">/</span>
      <nav class="header-nav" aria-label="Main navigation">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'header-nav-link',
              {
                active:
                  currentPath === item.href ||
                  (item.href !== '/' && currentPath.startsWith(item.href)),
              },
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
      <button
        type="button"
        class="header-mobile-trigger"
        aria-label="Toggle navigation"
        aria-expanded="false"
        data-nav-toggle
      >
        nav
      </button>
    </div>

    <div class="header-center"></div>

    <div class="header-right">
      <button type="button" class="header-icon-btn" aria-label="Search" data-search-open>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.35-4.35" />
        </svg>
      </button>
      <button type="button" class="header-icon-btn" aria-label="Toggle theme" data-theme-toggle>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" />
          <line x1="12" y1="1" x2="12" y2="3" />
          <line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" />
          <line x1="21" y1="12" x2="23" y2="12" />
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
      </button>
    </div>
  </div>

  <nav class="header-dropdown" aria-label="Mobile navigation" data-nav-dropdown hidden>
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'header-dropdown-link',
          {
            active:
              currentPath === item.href ||
              (item.href !== '/' && currentPath.startsWith(item.href)),
          },
        ]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const SCROLL_DEAD_ZONE = 5;
  const SCROLL_KEYS = new Set([
    'ArrowUp',
    'ArrowDown',
    'PageUp',
    'PageDown',
    'Home',
    'End',
    ' ',
  ]);
  let cleanupHeader: (() => void) | undefined;

  function syncHeaderState(root: HTMLElement, scrollY: number, isVisible: boolean) {
    root.dataset.headerScrolled = scrollY > 0 ? 'true' : 'false';
    root.dataset.headerVisible = isVisible ? 'true' : 'false';
  }

  function initHeader() {
    cleanupHeader?.();

    const root = document.documentElement;
    if (!document.querySelector('[data-header]')) return;

    // Mobile nav toggle
    const toggle = document.querySelector('[data-nav-toggle]');
    const dropdown = document.querySelector('[data-nav-dropdown]');
    let handleToggle: (() => void) | undefined;

    if (toggle && dropdown) {
      handleToggle = () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        dropdown.hidden = expanded;
      };

      toggle.addEventListener('click', handleToggle);
    }

    // Scroll-reveal behavior
    let lastScrollY = window.scrollY;
    let isVisible = true;
    let ticking = false;
    let frameId = 0;
    let suppressRevealUntilManualScroll = false;

    syncHeaderState(root, lastScrollY, isVisible);

    function markManualScrollIntent(event: Event) {
      const target = event.target;
      if (
        target instanceof Element &&
        target.closest('.toc-entry[href^="#"]')
      ) {
        return;
      }

      suppressRevealUntilManualScroll = false;
    }

    function onKeyDown(event: KeyboardEvent) {
      if (!SCROLL_KEYS.has(event.key)) return;
      markManualScrollIntent(event);
    }

    function onTocClick(event: Event) {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const tocLink = target.closest('.toc-entry[href^="#"]');
      if (!tocLink) return;

      suppressRevealUntilManualScroll = true;
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;

      frameId = requestAnimationFrame(() => {
        const currentScrollY = window.scrollY;
        const delta = currentScrollY - lastScrollY;

        if (currentScrollY <= 0) {
          isVisible = true;
          suppressRevealUntilManualScroll = false;
        } else if (delta > SCROLL_DEAD_ZONE) {
          // Scrolling down: hide
          isVisible = false;
        } else if (
          delta < -SCROLL_DEAD_ZONE &&
          !suppressRevealUntilManualScroll
        ) {
          // Scrolling up: show
          isVisible = true;
        }

        syncHeaderState(root, currentScrollY, isVisible);
        lastScrollY = currentScrollY;
        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('wheel', markManualScrollIntent, {
      passive: true,
    });
    window.addEventListener('touchmove', markManualScrollIntent, {
      passive: true,
    });
    window.addEventListener('pointerdown', markManualScrollIntent, {
      passive: true,
    });
    window.addEventListener('keydown', onKeyDown);
    document.addEventListener('click', onTocClick);

    const resetHeaderState = () => {
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('wheel', markManualScrollIntent);
      window.removeEventListener('touchmove', markManualScrollIntent);
      window.removeEventListener('pointerdown', markManualScrollIntent);
      window.removeEventListener('keydown', onKeyDown);
      document.removeEventListener('click', onTocClick);
      syncHeaderState(root, 0, true);
    };

    document.addEventListener('astro:before-preparation', resetHeaderState, { once: true });

    cleanupHeader = () => {
      if (frameId) {
        cancelAnimationFrame(frameId);
      }
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('wheel', markManualScrollIntent);
      window.removeEventListener('touchmove', markManualScrollIntent);
      window.removeEventListener('pointerdown', markManualScrollIntent);
      window.removeEventListener('keydown', onKeyDown);
      document.removeEventListener('click', onTocClick);
      document.removeEventListener('astro:before-preparation', resetHeaderState);
      if (toggle && handleToggle) {
        toggle.removeEventListener('click', handleToggle);
      }
    };
  }

  document.addEventListener('astro:page-load', initHeader);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeader);
  } else {
    initHeader();
  }
</script>
