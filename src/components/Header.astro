---
const navItems = [
  { href: '/', label: 'index' },
  { href: '/projects/', label: 'projects' },
  { href: '/blog/', label: 'blog' },
  { href: '/notes/', label: 'notes' },
  { href: '/contact', label: 'contact' }
];

function pageSlug(pathname: string) {
  return pathname.split('/').filter(Boolean).join('.');
}

const currentPath = Astro.url.pathname;
const slug = pageSlug(currentPath);
const siteName = slug ? `theor.net.${slug}` : 'theor.net';
---

<header class="header" data-header>
  <div class="header-inner">
    <a class="header-brand" href="/" aria-label={`${siteName} home`}>
      <span class="header-brand-mark" aria-hidden="true">@</span>
    </a>

    <nav class="header-nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'header-nav-link',
            {
              active:
                currentPath === item.href ||
                (item.href !== '/' && currentPath.startsWith(item.href)),
            },
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <button
        type="button"
        class="header-mobile-trigger ui-text-trigger"
        aria-label="Toggle navigation"
        aria-controls="header-nav-dropdown"
        aria-expanded="false"
        data-nav-toggle
      >
        menu
      </button>
      <button type="button" class="header-icon-btn" aria-label="Search" data-search-open>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.35-4.35" />
        </svg>
      </button>
      <button type="button" class="header-icon-btn" aria-label="Toggle theme" data-theme-toggle>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" />
          <line x1="12" y1="1" x2="12" y2="3" />
          <line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" />
          <line x1="21" y1="12" x2="23" y2="12" />
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="header-nav-dropdown"
    class="header-dropdown ui-sheet-soft"
    aria-label="Mobile navigation"
    data-nav-dropdown
    hidden
  >
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'header-dropdown-link',
          'ui-option-row',
          {
            active:
              currentPath === item.href ||
              (item.href !== '/' && currentPath.startsWith(item.href)),
          },
        ]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  import {
    subscribeThemeChange,
    syncThemeToggleLabel,
    toggleTheme,
  } from '@/scripts/theme';

  const SCROLL_DEAD_ZONE = 5;
  const HIDE_DISTANCE = 28;
  const SHOW_DISTANCE = 18;
  const SCROLL_KEYS = new Set([
    'ArrowUp',
    'ArrowDown',
    'PageUp',
    'PageDown',
    'Home',
    'End',
    ' ',
  ]);
  let cleanupHeader: (() => void) | undefined;

  function syncHeaderState(
    root: HTMLElement,
    scrollY: number,
    visible: boolean,
    docked: boolean
  ) {
    root.dataset.headerScrolled = scrollY > 0 ? 'true' : 'false';
    root.dataset.headerVisible = visible ? 'true' : 'false';
    root.dataset.headerDocked = docked ? 'true' : 'false';
  }

  function initHeader() {
    cleanupHeader?.();

    const root = document.documentElement;
    if (!document.querySelector('[data-header]')) return;

    // Mobile nav toggle
    const header = document.querySelector('[data-header]');
    const toggle = document.querySelector('[data-nav-toggle]');
    const dropdown = document.querySelector('[data-nav-dropdown]');
    const themeToggle = document.querySelector('[data-theme-toggle]');
    let handleToggle: (() => void) | undefined;
    let handleDocumentClick: ((event: Event) => void) | undefined;
    let handleDropdownClick: ((event: Event) => void) | undefined;
    let handleThemeToggle: (() => void) | undefined;
    let stopThemeSync: (() => void) | undefined;

    function closeDropdown() {
      if (!(toggle instanceof HTMLButtonElement) || !(dropdown instanceof HTMLElement)) {
        return;
      }

      toggle.setAttribute('aria-expanded', 'false');
      dropdown.hidden = true;
    }

    if (
      header instanceof HTMLElement &&
      toggle instanceof HTMLButtonElement &&
      dropdown instanceof HTMLElement
    ) {
      handleToggle = () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        dropdown.hidden = expanded;
      };

      handleDocumentClick = (event) => {
        const target = event.target;
        if (!(target instanceof Node)) return;
        if (header.contains(target)) return;
        closeDropdown();
      };

      handleDropdownClick = (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (!target.closest('a')) return;
        closeDropdown();
      };

      toggle.addEventListener('click', handleToggle);
      document.addEventListener('click', handleDocumentClick);
      dropdown.addEventListener('click', handleDropdownClick);
    }

    if (themeToggle instanceof HTMLButtonElement) {
      syncThemeToggleLabel(themeToggle);
      stopThemeSync = subscribeThemeChange((theme) => {
        syncThemeToggleLabel(themeToggle, theme);
      });
      handleThemeToggle = () => {
        toggleTheme();
      };
      themeToggle.addEventListener('click', handleThemeToggle);
    }

    // Scroll-reveal behavior
    const headerHeightValue = parseFloat(
      getComputedStyle(root).getPropertyValue('--height-header')
    );
    const headerHeight = Number.isFinite(headerHeightValue)
      ? headerHeightValue
      : 44;
    const dockThreshold = headerHeight;
    let lastScrollY = window.scrollY;
    let isVisible = lastScrollY <= dockThreshold;
    let ticking = false;
    let frameId = 0;
    let suppressRevealUntilManualScroll = false;
    let direction: 'up' | 'down' | null = null;
    let directionStartY = lastScrollY;

    syncHeaderState(root, lastScrollY, isVisible, lastScrollY <= dockThreshold);

    function resetDirectionState(scrollY = window.scrollY) {
      direction = null;
      directionStartY = Math.max(scrollY, 0);
    }

    function markManualScrollIntent(event: Event) {
      const target = event.target;
      if (
        target instanceof Element &&
        target.closest('.toc-entry[href^="#"]')
      ) {
        return;
      }

      suppressRevealUntilManualScroll = false;
      resetDirectionState();
    }

    function onKeyDown(event: KeyboardEvent) {
      if (event.key === 'Escape') {
        closeDropdown();
      }

      if (!SCROLL_KEYS.has(event.key)) return;
      markManualScrollIntent(event);
    }

    function onTocClick(event: Event) {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const tocLink = target.closest('.toc-entry[href^="#"]');
      if (!tocLink) return;

      suppressRevealUntilManualScroll = true;
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;

      frameId = requestAnimationFrame(() => {
        const currentScrollY = Math.max(window.scrollY, 0);
        const delta = currentScrollY - lastScrollY;
        const isDocked = currentScrollY <= dockThreshold;

        if (isDocked) {
          isVisible = true;
          suppressRevealUntilManualScroll = false;
          resetDirectionState(currentScrollY);
        } else if (Math.abs(delta) > SCROLL_DEAD_ZONE) {
          const nextDirection = delta > 0 ? 'down' : 'up';

          if (direction !== nextDirection) {
            direction = nextDirection;
            directionStartY = lastScrollY;
          }

          const travel = Math.abs(currentScrollY - directionStartY);

          if (
            direction === 'down' &&
            isVisible &&
            currentScrollY > headerHeight &&
            travel >= HIDE_DISTANCE
          ) {
            isVisible = false;
            closeDropdown();
            directionStartY = currentScrollY;
          } else if (
            direction === 'up' &&
            !isVisible &&
            travel >= SHOW_DISTANCE &&
            !suppressRevealUntilManualScroll
          ) {
            isVisible = true;
            directionStartY = currentScrollY;
          }
        }

        syncHeaderState(root, currentScrollY, isVisible, isDocked);
        lastScrollY = currentScrollY;
        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('wheel', markManualScrollIntent, {
      passive: true,
    });
    window.addEventListener('touchmove', markManualScrollIntent, {
      passive: true,
    });
    window.addEventListener('pointerdown', markManualScrollIntent, {
      passive: true,
    });
    window.addEventListener('keydown', onKeyDown);
    document.addEventListener('click', onTocClick);

    const resetHeaderState = () => {
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('wheel', markManualScrollIntent);
      window.removeEventListener('touchmove', markManualScrollIntent);
      window.removeEventListener('pointerdown', markManualScrollIntent);
      window.removeEventListener('keydown', onKeyDown);
      document.removeEventListener('click', onTocClick);
      if (handleDocumentClick) {
        document.removeEventListener('click', handleDocumentClick);
      }
      if (dropdown instanceof HTMLElement && handleDropdownClick) {
        dropdown.removeEventListener('click', handleDropdownClick);
      }
      if (themeToggle instanceof HTMLButtonElement && handleThemeToggle) {
        themeToggle.removeEventListener('click', handleThemeToggle);
      }
      stopThemeSync?.();
      closeDropdown();
      syncHeaderState(root, 0, true, true);
    };

    document.addEventListener('astro:before-preparation', resetHeaderState, { once: true });

    cleanupHeader = () => {
      if (frameId) {
        cancelAnimationFrame(frameId);
      }
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('wheel', markManualScrollIntent);
      window.removeEventListener('touchmove', markManualScrollIntent);
      window.removeEventListener('pointerdown', markManualScrollIntent);
      window.removeEventListener('keydown', onKeyDown);
      document.removeEventListener('click', onTocClick);
      document.removeEventListener('astro:before-preparation', resetHeaderState);
      if (toggle instanceof HTMLButtonElement && handleToggle) {
        toggle.removeEventListener('click', handleToggle);
      }
      if (handleDocumentClick) {
        document.removeEventListener('click', handleDocumentClick);
      }
      if (dropdown instanceof HTMLElement && handleDropdownClick) {
        dropdown.removeEventListener('click', handleDropdownClick);
      }
      if (themeToggle instanceof HTMLButtonElement && handleThemeToggle) {
        themeToggle.removeEventListener('click', handleThemeToggle);
      }
      stopThemeSync?.();
      closeDropdown();
    };
  }

  document.addEventListener('astro:page-load', initHeader);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeader);
  } else {
    initHeader();
  }
</script>
