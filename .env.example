# Project environment variables.
# Copy to .env automatically via Copier post-generation tasks.

ASTRO_TELEMETRY_DISABLED=1

# Optional Ghost integration. Without GHOST_CONTENT_API_KEY, Ghost pages/posts are skipped at build time.
GHOST_CONTENT_API_URL=https://ghost.theor.net/ghost/api/content
GHOST_CONTENT_API_KEY=
GHOST_ACTIVITYPUB_OUTBOX_URL=https://ghost.theor.net/.ghost/activitypub/outbox/index
PUBLIC_FEDIVERSE_HANDLE=@theoryzhenkov@ap.theor.net
PUBLIC_MASTODON_INSTANCE_URL=https://mastodon.social

# Web analytics is served by self-hosted Medama (stats.theor.net); the tracker
# snippet is embedded directly in Head.astro and needs no build-time config.
